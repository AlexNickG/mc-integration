# =============================================================================
# Example environment variables
# =============================================================================
#
# Copy this file as .env and set the variables:
#   cp .env.example .env
#
# IMPORTANT: .env has been added to .gitignore and will not be committed
# =============================================================================

# API URL для бэкенда (без trailing slash)
# For local development:
#VUE_APP_API_URL=http://localhost:8765/api/v1

# For production:
# VUE_APP_API_URL=http://<your-server-ip>:8765/api/v1

# Redis
#REDIS_PASS=change-me
SPRING_DATA_REDIS_HOST=localhost

# Yandex Cloud Object Storage / S3-compatible storage
YC_S3_ACCESS_KEY=your-s3-access-key
YC_S3_SECRET_KEY=your-s3-secret-key

# Режим окружения (dev / prod)
SPRING_PROFILES_ACTIVE=prod

# Service discovery
EUREKA_HOST=http://localhost:8761/eureka/

# JWT public key location.
# For local development you can use the classpath fallback from application.yaml:
# JWT_PUBLIC_KEY_PATH=classpath:/keys/public.pem
# For Docker/prod prefer a mounted file:
# JWT_PUBLIC_KEY_PATH=file:/app/keys/public.pem
JWT_PUBLIC_KEY_PATH=classpath:/keys/public.pem
